{
	"presets": [
		"@babel/preset-env",
		["@babel/preset-react", { "runtime": "automatic" }],
		"@babel/preset-typescript",
		"@wyw-in-js/babel-preset"
	],
	"plugins": [
		"./babel-plugins/babel-plugin-inject-linaria-css.js",
