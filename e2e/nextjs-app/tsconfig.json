{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
	"types": ["node"],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
	  "@lifesg/web-frontend-engine": ["../../src"],
	  "@lifesg/web-frontend-engine/*": ["../../src/*"],
      "@/*": [
        "./*"
      ],
	  "react": ["./node_modules/@types/react"],
	  "react-dom": ["./node_modules/@types/react-dom"],
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
